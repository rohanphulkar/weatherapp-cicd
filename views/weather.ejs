        "Mist": "धुंध",
        "Patchy rain nearby": "आसपास हल्की बारिश",
        "Patchy light rain with thunder": "गरज के साथ हल्की बारिश",
        "Moderate or heavy rain shower": "मध्यम या भारी बारिश",
        "Thundery outbreaks possible": "गरज के साथ आंधी संभव",
        "Blowing snow": "तेज हवा के साथ बर्फबारी",
        "Fog": "कोहरा",
        "Freezing fog": "जमता हुआ कोहरा",
        "Heavy rain": "भारी वर्षा",
        "Light rain": "हल्की बारिश",
        "Light drizzle": "हल्की बूंदाबांदी",
        "Moderate rain": "मध्यम वर्षा",
        "Yesterday": "कल",
        "2 Days Ago": "२ दिन पहले",
        "3 Days Ago": "३ दिन पहले",
        "Today": "आज",
        "Tomorrow": "कल",
        "Monday": "सोमवार",
        "Tuesday": "मंगलवार",
        "Wednesday": "बुधवार",
        "Thursday": "गुरुवार",
        "Friday": "शुक्रवार",
        "Saturday": "शनिवार",
        "Sunday": "रविवार",
        "Minimal Risk": "न्यूनतम जोखिम",
        "Moderate Risk": "सामान्य जोखिम",
        "High Risk!": "उच्च जोखिम!",
        "Excellent": "उत्कृष्ट",
        "Cool Breeze": "ठंडी हवा",
        "Heavy Heat": "अत्यधिक गर्मी",
        "Waxing Gibbous": "वैक्सिंग गिब्बस",
        "Waning Gibbous": "वानिंग गिब्बस",
        "New Moon": "अमावस्या",
        "Full Moon": "पूर्णिमा",
        "Waxing Crescent": "वैक्सिंग क्रीसेंट",
        "Waning Crescent": "वानिंग क्रीसेंट",
        "First Quarter": "प्रथम चतुर्थांश",
        "Third Quarter": "तृतीय चतुर्थांश"
      };

      // Active language setting (persisted in localStorage)
      let activeLanguage = localStorage.getItem('aethera_lang') || 'en';

      function setLanguage(lang) {
        activeLanguage = lang;
        localStorage.setItem('aethera_lang', lang);
        
        // Synchronize select dropdown value in navbar
        const langSelect = document.getElementById('langSelect');
        if (langSelect) {
          langSelect.value = lang;
        }

        // Apply translations to static tags
        document.querySelectorAll('[data-translate]').forEach(el => {
          const key = el.getAttribute('data-translate');
          if (translations[lang] && translations[lang][key]) {
            el.textContent = translations[lang][key];
          }
        });

        // Translate dynamic values returned from the API
        document.querySelectorAll('.translate-val').forEach(el => {
          const original = el.getAttribute('data-orig-val') || el.textContent.trim();
          if (!el.getAttribute('data-orig-val')) {
            el.setAttribute('data-orig-val', original);
          }

          if (lang === 'hi') {
            if (weatherTerms[original]) {
              el.textContent = weatherTerms[original];
            } else {
              // Try localized word replacements
              let modified = original;
              Object.keys(weatherTerms).forEach(key => {
                modified = modified.replace(new RegExp(key, 'g'), weatherTerms[key]);
              });
              el.textContent = modified;
            }
          } else {
            el.textContent = original;
          }
        });

        // Translate input placeholders
        const input = document.getElementById('searchInput');
        if (input) {
          input.placeholder = translations[lang].search_placeholder;
        }

        // Re-translate history if loaded
        if (typeof historyLoaded !== 'undefined' && historyLoaded) {
          translateHistoryGrid(lang);
        }
      }

      function translateHistoryGrid(lang) {
        document.querySelectorAll('#historyGrid .history-card').forEach(card => {
          // Translate card titles
          const title = card.querySelector('.history-day-title');
          if (title) {
            const orig = title.getAttribute('data-orig-val') || title.textContent.trim();
            if (!title.getAttribute('data-orig-val')) title.setAttribute('data-orig-val', orig);
            title.textContent = lang === 'hi' ? (weatherTerms[orig] || orig) : orig;
          }

          // Translate range label
          const rangeSpan = card.querySelector('.history-temp-sub span[data-translate="range_label"]');
          if (rangeSpan) {
            rangeSpan.textContent = lang === 'hi' ? 'तापमान सीमा: ' : 'Range: ';
          }

          // Translate metrics labels
          card.querySelectorAll('.history-metric-box').forEach(box => {
            const labelSpan = box.querySelector('span:first-child');
            if (labelSpan) {
              const orig = labelSpan.getAttribute('data-orig-val') || labelSpan.textContent.trim();
              if (!labelSpan.getAttribute('data-orig-val')) labelSpan.setAttribute('data-orig-val', orig);
              
              if (lang === 'hi') {
                if (orig === 'Humidity') labelSpan.textContent = 'आर्द्रता';
                if (orig === 'Wind Max') labelSpan.textContent = 'अधिकतम हवा';
              } else {
                labelSpan.textContent = orig;
              }
            }
          });

          // Translate footer condition
          const footerDiv = card.querySelector('div[style*="font-size: 11px"]');
          if (footerDiv) {
            const orig = footerDiv.getAttribute('data-orig-val') || footerDiv.textContent.trim();
            if (!footerDiv.getAttribute('data-orig-val')) footerDiv.setAttribute('data-orig-val', orig);
            footerDiv.textContent = lang === 'hi' ? (weatherTerms[orig] || orig) : orig;
          }
        });
      }



      // Initialize translation on page load
      window.addEventListener('DOMContentLoaded', () => {
        setLanguage(activeLanguage);
      });

      // DYNAMIC SEARCH AUTOCOMPLETE LOGIC
      const searchInput = document.getElementById('searchInput');
      const autocompleteDropdown = document.getElementById('autocompleteDropdown');
      const searchSpinner = document.getElementById('searchSpinner');
      const searchForm = document.getElementById('searchForm');
      
      let debounceTimeout = null;
      let activeItemIndex = -1;

      if (searchInput && autocompleteDropdown) {
        searchInput.addEventListener('input', (e) => {
          const value = e.target.value.trim();
          clearTimeout(debounceTimeout);
          
          if (value.length < 2) {
            hideDropdown();
            return;
          }

          // Trigger loading spinner
          if (searchSpinner) searchSpinner.style.display = 'block';

          // Debounce network requests by 300ms
          debounceTimeout = setTimeout(() => {
            fetch(`/api/search?q=${encodeURIComponent(value)}`)
              .then(res => res.json())
              .then(data => {
                if (searchSpinner) searchSpinner.style.display = 'none';
                renderSuggestions(data);
              })
              .catch(err => {
                console.error("Autocomplete error:", err);
                if (searchSpinner) searchSpinner.style.display = 'none';
              });
          }, 300);
        });

        // Keyboard navigation accessibility
        searchInput.addEventListener('keydown', (e) => {
          const items = autocompleteDropdown.querySelectorAll('.autocomplete-item');
          if (!items.length) return;

          if (e.key === 'ArrowDown') {
            e.preventDefault();
            activeItemIndex = (activeItemIndex + 1) % items.length;
            highlightItem(items);
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            activeItemIndex = (activeItemIndex - 1 + items.length) % items.length;
            highlightItem(items);
          } else if (e.key === 'Enter') {
            if (activeItemIndex > -1) {
              e.preventDefault();
              items[activeItemIndex].click();
            }
          } else if (e.key === 'Escape') {
            hideDropdown();
          }
        });

        // Hide autocomplete when clicking elsewhere
        document.addEventListener('click', (e) => {
          if (!searchInput.contains(e.target) && !autocompleteDropdown.contains(e.target)) {
            hideDropdown();
          }
        });
      }

      function highlightItem(items) {
        items.forEach((item, idx) => {
          if (idx === activeItemIndex) {
            item.classList.add('active');
            // Auto scroll suggestion into view
            item.scrollIntoView({ block: 'nearest' });
          } else {
            item.classList.remove('active');
          }
        });
      }

      function renderSuggestions(list) {
        autocompleteDropdown.innerHTML = '';
        activeItemIndex = -1;

        if (!list || !list.length) {
          hideDropdown();
          return;
        }

        list.forEach(item => {
          const li = document.createElement('li');
          li.className = 'autocomplete-item';
          li.innerHTML = `
            <i data-lucide="map-pin" style="width: 14px; height: 14px; color: var(--accent);"></i>
            <span>${item.name}</span>
            <span class="region-country">${item.region ? item.region + ', ' : ''}${item.country}</span>
          `;
          
          li.addEventListener('click', () => {
            searchInput.value = item.name;
            hideDropdown();
            searchForm.submit();
          });
          
          autocompleteDropdown.appendChild(li);
        });

        // Trigger Lucide updates for icons in autocomplete
        lucide.createIcons();
        autocompleteDropdown.style.display = 'block';
      }

      function hideDropdown() {
        autocompleteDropdown.style.display = 'none';
        autocompleteDropdown.innerHTML = '';
        activeItemIndex = -1;
      }

      // ASYNCHRONOUS HISTORY COLLAPSIBLE ACCORDION LOGIC
      const historyToggleBtn = document.getElementById('historyToggleBtn');
      const historyDrawer = document.getElementById('historyDrawer');
      const historyChevron = document.getElementById('historyChevron');
      const historySkeleton = document.getElementById('historySkeleton');
      const historyGrid = document.getElementById('historyGrid');
      
      let historyLoaded = false;
      const currentQueryCity = "<%= error ? '' : location.name %>";

      if (historyToggleBtn && historyDrawer) {
        historyToggleBtn.addEventListener('click', () => {
          const isOpen = historyDrawer.classList.contains('open');
          
          if (isOpen) {
            // Close drawer
            historyDrawer.classList.remove('open');
            if (historyChevron) historyChevron.classList.remove('rotated');
          } else {
            // Open drawer
            historyDrawer.classList.add('open');
            if (historyChevron) historyChevron.classList.add('rotated');
            
            // If data is not yet loaded, trigger fetch
            if (!historyLoaded && currentQueryCity) {
              fetchHistoricalData(currentQueryCity);
            }
          }
        });
      }

      function fetchHistoricalData(city) {
        if (historySkeleton) historySkeleton.style.display = 'flex';
        if (historyGrid) historyGrid.style.display = 'none';

        fetch(`/api/history?q=${encodeURIComponent(city)}`)
          .then(res => {
            if (!res.ok) throw new Error("Failed to load records");
            return res.json();
          })
          .then(data => {
            renderHistoryData(data);
            historyLoaded = true;
          })
          .catch(err => {
            console.error("History fetching error:", err);
            if (historySkeleton) {
              const errMsg = translations[activeLanguage].history_err;
              historySkeleton.innerHTML = `
                <div class="glass-card error-card" style="width: 100%; min-height: 200px; padding: 2rem;">
                  <i data-lucide="cloud-off" style="width: 24px; height: 24px; color: #ef4444;"></i>
                  <p style="font-size: 13px; color: var(--text-secondary);">${errMsg}</p>
                </div>
              `;
              lucide.createIcons();
            }
          });
      }

      function renderHistoryData(days) {
        if (!historyGrid) return;
        historyGrid.innerHTML = '';
        
        days.forEach(day => {
          const card = document.createElement('div');
          card.className = 'history-card';
          
          // Localization tags applied automatically on creation
          card.innerHTML = `
            <span class="history-day-title" data-orig-val="${day.dayName}">${activeLanguage === 'hi' ? (weatherTerms[day.dayName] || day.dayName) : day.dayName}</span>
            <span class="history-date">${day.formattedDate}</span>
            <img src="https:${day.conditionIcon}" alt="${day.conditionText}" class="history-icon" />
            <div class="history-temp">${day.avgTemp}°C</div>
            <div class="history-temp-sub"><span data-translate="range_label">${activeLanguage === 'hi' ? 'तापमान सीमा: ' : 'Range: '}</span>${day.tempMin}°C - ${day.tempMax}°C</div>
            <div class="history-metrics">
              <div class="history-metric-box">
                <span data-orig-val="Humidity">${activeLanguage === 'hi' ? 'आर्द्रता' : 'Humidity'}</span>
                <span>${day.humidity}%</span>
              </div>
              <div class="history-metric-box">
                <span data-orig-val="Wind Max">${activeLanguage === 'hi' ? 'अधिकतम हवा' : 'Wind Max'}</span>
                <span>${day.windKph} <span style="font-size:9px">km/h</span></span>
              </div>
            </div>
            <div style="font-size: 11px; font-weight:600; color: var(--text-secondary); margin-top:0.25rem" data-orig-val="${day.conditionText}">
              ${activeLanguage === 'hi' ? (weatherTerms[day.conditionText] || day.conditionText) : day.conditionText}
            </div>
          `;
          historyGrid.appendChild(card);
        });

        // Hide skeleton & display actual historical grid content
        if (historySkeleton) historySkeleton.style.display = 'none';
        historyGrid.style.display = 'grid';
      }
    </script>
  </body>
</html>
